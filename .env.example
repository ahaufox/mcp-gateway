# ============================================================
# MCP Gateway 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据需要修改：
#   cp .env.example .env
# ============================================================

# --- douyin-mcp 服务 ---

# 硅基流动 / 阿里云百炼 API 密钥（语音转文字功能必需）
# 获取地址: https://cloud.siliconflow.cn 或 https://bailian.console.aliyun.com
API_KEY=

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# MCP 传输模式 (stdio / sse / streamable-http)
MCP_TRANSPORT=stdio

# SSE/HTTP 模式监听端口
MCP_PORT=8000