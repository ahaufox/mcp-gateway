# ============================================================
# MCP Proxy 环境变量配置
# ============================================================
# 复制此文件为 .env 并根据需要修改：
#   cp .env.example .env
# ============================================================

# GitHub 个人访问令牌（用于访问 GitHub API）
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Jules API 密钥
JULES_API_KEY=your_jules_api_key_here

# Stitch API 密钥（用于 X-Goog-Api-Key 请求头）
STITCH_API_KEY=your_stitch_api_key_here

# 认证令牌（config.json 中引用 ${AUTH_TOKENS}）
AUTH_TOKENS=DefaultTokens

# MCP 服务基础地址
MCP_BASE_URL=https://localhost:9090

# 抖音 MCP 服务 API 密钥
DOUYIN_MCP_API_KEY=change_me


# Notion API 认证（JSON 格式字符串）
# 格式: '{"Authorization": "Bearer your_notion_token", "Notion-Version": "2022-06-28"}'
NOTION_OPENAPI_HEADERS='{"Authorization": "Bearer your_notion_token_here", "Notion-Version": "2022-06-28"}'

# 内部 MCP 服务地址
JULES_MCP_URL=http://jules-mcp-server:8000/sse
DOUYIN_MCP_URL=http://douyin-mcp:8000/sse